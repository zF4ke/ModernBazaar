# ── Copy to infra/.env and fill in. NEVER commit the real .env (it's gitignored). ──

# Database
POSTGRES_DB=bazaar
POSTGRES_USER=bazaar
POSTGRES_PASSWORD=bazaar

SPRING_DATASOURCE_URL="jdbc:postgresql://db:5432/${POSTGRES_DB}"
SPRING_PROFILES_ACTIVE=docker

# Optional HTTP Basic / actuator creds + Grafana
SPRING_SECURITY_USER_NAME=
SPRING_SECURITY_USER_PASSWORD=
GRAFANA_ADMIN_PASSWORD=

#keytool -genkeypair -alias tomcat -keyalg RSA -keysize 2048 -storetype PKCS12 -keystore keystore.p12 -storepass PASSWORD -keypass PASSWORD -dname "CN=localhost, OU=Dev, O=ModernBazaar, L=Lisbon, ST=Lisbon, C=PT"
KEYSTORE_PASSWORD=

# ── Auth0 (resource server) ──────────────────────────────────────────────
# REQUIRED in any real environment. With a real JWKS URI the app validates
# tokens for real. If AUTH_JWKS_URI is blank AND AUTH_MOCK_ENABLED is not true,
# the backend refuses to start (fail-closed).
AUTH_ISSUER_URI=https://YOUR_TENANT.us.auth0.com/
AUTH_JWKS_URI=https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json
AUTH_AUDIENCE=https://modern-bazaar.api

# Auth0 Management API (automatic role assignment). From a M2M application
# authorized for the Management API.
AUTH_MANAGEMENT_CLIENT_ID=
AUTH_MANAGEMENT_CLIENT_SECRET=

# DANGER: true makes the backend trust ANY token with full admin scopes.
# Local development ONLY. Leave unset/false everywhere else.
AUTH_MOCK_ENABLED=false

# Admin bootstrap: comma-separated Auth0 subs granted manage:plans server-side.
# Find your sub at /dashboard/profile. Example:
# ADMIN_USER_SUBS=google-oauth2|1234567890,auth0|abc123
ADMIN_USER_SUBS=

# Production only: exact HTTPS dashboard origin(s), comma-separated.
# Leave blank for local dev (defaults to localhost + the vercel host).
# CORS_ALLOWED_ORIGINS=https://your-dashboard-domain

# ── Payments: Lemon Squeezy (Merchant of Record) ─────────────────────────
# Set BILLING_ENABLED=true only after the webhook secret is set, else the
# webhook fails closed. Secret: Lemon Squeezy → Settings → Webhooks.
# NOTE: escape any '$' in these values as '$$' — Compose interpolates env_file.
BILLING_ENABLED=false
LEMONSQUEEZY_WEBHOOK_SECRET=
# API key (Lemon Squeezy → Settings → API). Powers server-side actions: the user
# "Cancel subscription" flow and auto-cancelling a duplicate subscription to avoid
# double billing. Optional — without it those actions are only logged, not performed.
LEMONSQUEEZY_API_KEY=
