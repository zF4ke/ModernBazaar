# Copy to infra/.env on the Droplet. Do not commit real secrets.

POSTGRES_DB=bazaar
POSTGRES_USER=bazaar
POSTGRES_PASSWORD=replace-with-a-strong-password

GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# Caddy basic-auth line for Prometheus:
#   caddy hash-password --plaintext 'your-password'
# Then set: PROMETHEUS_BASIC_AUTH=admin <hash>
PROMETHEUS_BASIC_AUTH=admin replace-with-caddy-bcrypt-hash

AUTH_ISSUER_URI=https://YOUR_TENANT.us.auth0.com/
AUTH_JWKS_URI=https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json
AUTH_AUDIENCE=https://modern-bazaar.api
AUTH_MANAGEMENT_CLIENT_ID=
AUTH_MANAGEMENT_CLIENT_SECRET=
AUTH_MOCK_ENABLED=false
ADMIN_USER_SUBS=

CORS_ALLOWED_ORIGINS=https://modernbazaar.zf4ke.me,https://modern-bazaar.vercel.app

BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://modernbazaar.zf4ke.me/dashboard/profile?checkout=success
STRIPE_CANCEL_URL=https://modernbazaar.zf4ke.me/dashboard/profile?checkout=cancelled
STRIPE_PORTAL_RETURN_URL=https://modernbazaar.zf4ke.me/dashboard/profile

# Optional live price IDs. Leave blank until billing is ready.
# STRIPE_PRICE_FLIPPER=price_...
# STRIPE_PRICE_ELITE=price_...
