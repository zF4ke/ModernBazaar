# ── Auth0 (nextjs-auth0 v4) ────────────────────────────────────────────────
# The Auth0 application MUST be a "Regular Web Application" (confidential client),
# not a SPA, because v4 uses server-side sessions and needs the client secret.
#
# In your Auth0 application settings add:
#   Allowed Callback URLs: http://localhost:3001/auth/callback
#   Allowed Logout URLs:   http://localhost:3001
#   Allowed Web Origins:   http://localhost:3001
AUTH0_DOMAIN=dev-5dw1c9bd.us.auth0.com
AUTH0_CLIENT_ID=your-regular-web-app-client-id
AUTH0_CLIENT_SECRET=your-regular-web-app-client-secret
# 32-byte hex secret used to encrypt the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_SECRET=replace-with-a-32-byte-hex-secret
# Public base URL of the dashboard (the dev server runs on port 3001).
APP_BASE_URL=http://localhost:3001
# Audience of the Spring backend API (so the access token is accepted by it).
AUTH0_AUDIENCE=https://modern-bazaar.api

# ── Backend ────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8080
NODE_ENV=development

# ── Payments: Lemon Squeezy hosted checkout links (public) ──────────────────
# Per-product checkout URLs (Lemon Squeezy → product → Share). Only the two paid
# plans need one; Free has no checkout. Leave blank until billing is live — the
# Upgrade button falls back to the pricing section.
NEXT_PUBLIC_LS_CHECKOUT_FLIPPER=
NEXT_PUBLIC_LS_CHECKOUT_ELITE=
